# XenoTech .gitignore
# Common ignores for Python, Rust, Go, Node, Docker, and general dev

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Rust
/target/
**/*.rs.bk
Cargo.lock

# Go
bin/
pkg/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Node.js / npm
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Docker
.dockerignore

# IDEs and editors
.idea/
.vscode/
*.swp
*.swo
*~

# OS generated
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Secrets and environment
.env
.env.local
.env.*.local
*.pem
*.key
secrets/

# Logs and temp
*.log
*.tmp
*.temp

# Build artifacts
build/
dist/
out/
